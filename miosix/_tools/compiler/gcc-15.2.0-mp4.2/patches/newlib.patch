diff -ruN newlib-4.6.0.20260123-old/newlib/libc/sys/miosix/termios.c newlib-4.6.0.20260123/newlib/libc/sys/miosix/termios.c
--- newlib-4.6.0.20260123-old/newlib/libc/sys/miosix/termios.c	1970-01-01 01:00:00.000000000 +0100
+++ newlib-4.6.0.20260123/newlib/libc/sys/miosix/termios.c	2026-02-05 15:44:09.006380225 +0100
@@ -0,0 +1,46 @@
+
+#include <termios.h>
+#include <errno.h>
+#include <sys/ioctl.h>
+
+int tcgetattr(int fd, struct termios *t)
+{
+    return ioctl(fd,IOCTL_TCGETATTR,(void*)t);
+}
+
+int tcsetattr(int fd, int opt, const struct termios *t)
+{
+    switch(opt)
+    {
+        case TCSAFLUSH:
+            return ioctl(fd,IOCTL_TCSETATTR_FLUSH,(void*)t);
+        case TCSANOW:
+            return ioctl(fd,IOCTL_TCSETATTR_NOW,(void*)t);
+        case TCSADRAIN:
+            return ioctl(fd,IOCTL_TCSETATTR_DRAIN,(void*)t);
+        default:
+            errno = EINVAL;
+            return -1;
+    }
+}
+
+speed_t cfgetospeed(const struct termios *t)
+{
+    return t->c_cflag & 0x00ffffff;
+}
+
+int cfsetospeed(struct termios *t, speed_t speed)
+{
+    t->c_cflag = (t->c_cflag & (~0x00ffffff)) | speed;
+    return 0;
+}
+
+int tcdrain(int fd)
+{
+    return ioctl(fd,IOCTL_SYNC,0);
+}
+
+int tcflush(int fd, int opt)
+{
+    return ioctl(fd,IOCTL_FLUSH,(void*)opt);
+}
