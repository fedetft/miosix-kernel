+    //debug_rtx(orig);
+    //if(SYMBOL_REF_DECL(orig)) debug_tree(SYMBOL_REF_DECL(orig));
+    
+    bool result = false;
+    const_tree decl = SYMBOL_REF_DECL(orig);
