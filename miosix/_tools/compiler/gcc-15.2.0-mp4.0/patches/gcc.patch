+                result = true;
+                //printf("constant (TYPE_READONLY)\n\n");
+            } else {
+                /*
+                 * Variables, testcase (compile with -O2)
+                 * extern int aData;
+                 * int get() { return aData; }
+                 */
+                //printf("variable (decl!=0)\n\n");
+            }
